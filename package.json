{
	"name": "obsidian-knewrova-plugin",
	"version": "0.0.0",
	"description": "Obsidian plugin with Biome/Oxlint/Vitest stack",
	"main": "main.js",
	"type": "commonjs",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"lint": "oxlint . && biome check .",
		"format": "biome check --write --unsafe .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"prepare": "pnpm run build",
		"version": "node scripts/version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.24.0",
		"jsdom": "^26.0.0",
		"obsidian": "latest",
		"oxlint": "^0.15.0",
		"tslib": "2.6.0",
		"typescript": "^5.6.0",
		"vitest": "^3.0.0"
	}
}
