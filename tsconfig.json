{
	"compilerOptions": {
		/* --- Base Config (Alias & Path) --- */
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},

		/* --- Output & Module --- */
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2018",
		"allowJs": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,

		/* --- Libraries & Types --- */
		"lib": ["DOM", "ES5", "ES6", "ES7", "ES2018"],
		"types": ["node"],

		/* --- Strict Type Checks (From Official Docs) --- */
		/* これらを有効にすることで、予期せぬundefinedエラー等を防ぎます */
		"noImplicitAny": true,
		"noImplicitThis": true,
		"noImplicitReturns": true,
		"noUncheckedIndexedAccess": true,
		"strictNullChecks": true,
		"strictBindCallApply": true,
		"allowSyntheticDefaultImports": true,
		"useUnknownInCatchVariables": true
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
